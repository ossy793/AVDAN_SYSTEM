# ─────────────────────────────────────────────────────────────────────────────
#  AVDAN Logistics Platform — Environment Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="AVDAN Logistics Platform"
APP_VERSION="1.0.0"
DEBUG=false

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
# Render PostgreSQL format: postgresql+asyncpg://USER:PASS@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME

# ── Demo mode ─────────────────────────────────────────────────────────────────
# Set true to skip real Monnify calls (payments auto-confirmed instantly)
DEMO_MODE=false

# ── Monnify ───────────────────────────────────────────────────────────────────
# Get from https://app.monnify.com/developer — API Keys section
MONNIFY_API_KEY=MK_TEST_your_key_here
MONNIFY_SECRET_KEY=your_secret_here
MONNIFY_CONTRACT_CODE=your_contract_code_here
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_WALLET_ACCOUNT=
MONNIFY_REDIRECT_URL=https://avdan-system-9ksg.vercel.app/customer/index.html

# ── Platform Financial Config (NGN) ───────────────────────────────────────────
PLATFORM_FEE_PERCENTAGE=5.0
DELIVERY_BASE_FEE=500.0
HUB_FEE=100.0

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your actual Vercel deployment URL(s)
ALLOWED_ORIGINS=["https://avdan-system-9ksg.vercel.app","https://avdan-admin.vercel.app","https://avdan-vendor.vercel.app","https://avdan-riders.vercel.app","https://avdan-agent.vercel.app","https://avdan-system.vercel.app"]

# ── Notification Providers (optional) ────────────────────────────────────────
SMS_PROVIDER_API_KEY=
WHATSAPP_PROVIDER_API_KEY=
